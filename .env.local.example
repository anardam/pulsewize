# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here  # NEVER NEXT_PUBLIC_
CONNECTED_ACCOUNT_TOKEN_SECRET=your-long-random-secret
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# OpenRouter
OPENROUTER_API_KEY=your-openrouter-api-key-here

# RapidAPI
RAPIDAPI_KEY=your-rapidapi-key-here

# Google / YouTube connected accounts
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/connections/youtube/callback

# Meta connected accounts
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
META_INSTAGRAM_APP_ID=your-instagram-app-id
META_INSTAGRAM_APP_SECRET=your-instagram-app-secret
META_INSTAGRAM_REDIRECT_URI=http://localhost:3000/api/connections/instagram/callback
META_FACEBOOK_REDIRECT_URI=http://localhost:3000/api/connections/facebook/callback

# X / Twitter connected accounts
X_CLIENT_ID=your-x-client-id
X_OAUTH_REDIRECT_URI=http://localhost:3000/api/connections/twitter/callback

NEXT_PUBLIC_DISABLE_USAGE_LIMITS=false

# Stripe billing
STRIPE_SECRET_KEY=sk_live_or_test
STRIPE_PRICE_ID=price_123
STRIPE_WEBHOOK_SECRET=whsec_123

# Admin
ADMIN_EMAILS=founder@example.com,ops@example.com

# @tesserix private registry auth
TESSERIX_NPM_TOKEN=your-tesserix-registry-token
